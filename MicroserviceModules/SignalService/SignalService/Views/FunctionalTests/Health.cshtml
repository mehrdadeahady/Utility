@{
    ViewData["Title"] = "Health Check";
}
<div class="container py-4">
    <h2 class="text-center mb-4">System Health Check</h2>

    <div class="text-center mb-4">
        <button class="btn btn-primary btn-lg px-4" onclick="runHealthCheck()">
            Run Health Check
        </button>
    </div>

    <div id="healthCard" class="card shadow-sm d-none">
        <div class="card-body">
            <h4 class="card-title mb-3">
                Overall Status:
                <span id="overallStatus" class="badge bg-secondary"></span>
            </h4>

            <table class="table table-striped table-bordered mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>Service</th>
                        <th>Status</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody id="healthTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

<script>
async function runHealthCheck() {
    const res = await fetch('/FunctionalTests/RunHealthCheck', { method: 'POST' });
    const json = await res.json();

    document.getElementById('healthCard').classList.remove('d-none');

    const status = json.status;
    const badge = document.getElementById('overallStatus');
    badge.textContent = status;

    badge.className = "badge";
    if (status === "Healthy") badge.classList.add("bg-success");
    else if (status === "Degraded") badge.classList.add("bg-warning");
    else badge.classList.add("bg-danger");

    const table = document.getElementById('healthTableBody');
    table.innerHTML = "";

    for (const [key, value] of Object.entries(json.results)) {
        table.innerHTML += `
            <tr>
                <td>${key}</td>
                <td>
                    <span class="badge bg-${value.status === "Healthy" ? "success" : value.status === "Degraded" ? "warning" : "danger"}">
                        ${value.status}
                    </span>
                </td>
                <td>${value.description ?? ""}</td>
            </tr>
        `;
    }
}
</script>
